# ── LLM Configuration ──────────────────────────────────────────
# Groq cloud (recommended for large context)
MODEL_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-groq-70b-8192-tool-use-preview
MAX_TOKENS=8000

# Optional: LM Studio local server (no API key needed)
# MODEL_PROVIDER=lmstudio
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_TEMPERATURE=0.7
LMSTUDIO_AUTO_SELECT=true

# Optional: Ollama local fallback
# MODEL_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5-coder:7b

# ── Tool Configuration ────────────────────────────────────────
TAVILY_API_KEY=
WORKSPACE_DIR=./workspace
SKILLS_DIR=./skills
MAX_TOOL_ATTEMPTS=3
RECURSION_LIMIT=50
MAX_HISTORY_MESSAGES=50
MAX_SKILL_CONTEXT_CHARS=20000
MAX_MEMORY_SUMMARY_CHARS=10000
MAX_INPUT_CHARS=100000
MAX_VALIDATION_ATTEMPTS=1
SYSTEM_PROMPT_VARIANT=runtime
MAX_SYSTEM_PROMPT_CHARS=30000
MAX_SYSTEM_RULES_CHARS=10000
MAX_EXTRA_INSTRUCTIONS_CHARS=10000
MAX_INSTRUCTION_SNIPPETS=5
CHAT_STREAM_TIMEOUT_SECONDS=300
CHECKPOINTER_BACKEND=sqlite
CHECKPOINTS_DIR=./checkpoints
CHECKPOINTS_DB_PATH=./checkpoints/friday_state.sqlite

# ── Command Execution ─────────────────────────────────────────
# Max seconds a subprocess may run (increase for npm/npx commands)
COMMAND_TIMEOUT=120

# Comma-separated command prefixes allowed for shell execution.
# Only the first token of a command is checked against this list.
COMMAND_ALLOWLIST=python,pip,npm,npx,node,mkdir,ls,dir,cat,type,echo,git,cd,pwd,touch,cp,copy,mv,move,head,tail,find,grep,curl,wget,pytest,cargo,dotnet,go,java,javac,gcc,g++,make,cmake,tsc,eslint,prettier

# Explicitly blocked command prefixes (applied even if present in allowlist).
COMMAND_DENYLIST=curl,wget

# Dynamic MCP tool invocation timeout (seconds).
MCP_TIMEOUT_SECONDS=20

# ── Project Scaffolding (outside workspace) ───────────────────
# Comma-separated absolute paths where the agent may scaffold projects.
# Leave empty to restrict everything to WORKSPACE_DIR.
ALLOWED_TARGET_DIRS=D:/Projects

# ── CORS ───────────────────────────────────────────────────────
NEXTJS_ORIGIN=http://localhost:3000
